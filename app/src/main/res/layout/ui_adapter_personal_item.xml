<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="itemBean"
            type="com.wantime.wbangapp.model.PersonalBean" />

        <variable
            name="itemClick"
            type="com.wantime.wbangapp.ui.adapter.RecyclerItemClick" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        style="@style/ui_fragment_personal_recycle_item"
        android:onClick="@{(view)->itemClick.onItemClick(view,itemBean)}">

        <ImageView
            android:id="@+id/personIcon"
            style="@style/ui_fragment_personal_recycle_item_icon"
            android:layout_marginStart="15dp"
            android:layout_marginLeft="15dp"
            android:src="@{itemBean.icon}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/personName"
            style="@style/ui_fragment_personal_recycle_item_name"
            android:layout_marginStart="15dp"
            android:layout_marginLeft="15dp"
            android:text="@{itemBean.title}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/personIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/personArrow"
            style="@style/ui_fragment_personal_recycle_item_arrow"
            android:layout_marginEnd="15dp"
            android:layout_marginRight="15dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <View
            style="@style/ui_fragment_personal_recycle_item_line"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="@+id/personName"
            app:layout_constraintRight_toRightOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
