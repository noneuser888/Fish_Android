<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/match_parent_style">

    <androidx.constraintlayout.widget.ConstraintLayout
        style="@style/ui_message_protol_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/protolTextView"
            style="@style/ui_protol_message_text"
            android:layout_height="0dp"
            android:scrollbars = "none"
            app:layout_constraintBottom_toTopOf="@+id/lineView"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <View
            android:id="@+id/lineView"
            style="@style/ui_common_wmatch_hwrap"
            android:layout_height="1px"
            android:layout_marginBottom="5dp"
            android:background="@color/gray_text_color"
            app:layout_constraintBottom_toTopOf="@+id/confirmText"
            app:layout_constraintLeft_toLeftOf="parent" />

        <TextView
            android:id="@+id/confirmText"
            style="@style/ui_message_alert_layout_button"
            android:layout_marginBottom="5dp"
            android:text="@string/close"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
