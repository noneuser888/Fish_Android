<?xml version="1.0" encoding="utf-8"?>
<layout>

    <data>

        <variable
            name="xNewsBean"
            type="com.wantime.wbangapp.model.AgentMangerBean.RecordsBean" />

        <variable
            name="xItemClick"
            type="com.wantime.wbangapp.ui.adapter.RecyclerAdapterItemClick" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        style="@style/ui_common_wmatch_hwrap"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/userName"
            style="@style/new_ui_agent_manager_item_name"
            android:text="@{xNewsBean.phone}"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/userNick"
            style="@style/new_ui_agent_manager_item_desc"
            android:text='@{xNewsBean.nickname}'
            app:layout_constraintLeft_toLeftOf="@+id/userName"
            app:layout_constraintTop_toBottomOf="@+id/userName" />

        <TextView
            android:id="@+id/userRemark"
            style="@style/new_ui_agent_manager_item_desc"
            android:text='@{@string/new_ui_remark+xNewsBean.remark}'
            app:layout_constraintLeft_toLeftOf="@+id/userNick"
            app:layout_constraintTop_toBottomOf="@+id/userNick" />

        <TextView
            android:id="@+id/userBalance"
            style="@style/new_ui_agent_manager_item_desc"
            android:text="@{@string/new_ui_balance+String.valueOf(xNewsBean.balance)}"
            app:layout_constraintLeft_toLeftOf="@+id/userName"
            app:layout_constraintTop_toBottomOf="@+id/userRemark" />


        <ImageView
            android:id="@+id/addRemark"
            style="@style/new_ui_agent_manager_remark"
            android:onClick="@{(view)->xItemClick.onItemClick(view,xNewsBean,0)}"
            app:layout_constraintLeft_toRightOf="@+id/userName"
            app:layout_constraintTop_toTopOf="@+id/userName" />

        <TextView
            android:id="@+id/upgradeButton"
            style="@style/new_ui_agent_manager_recharge"
            android:visibility="@{xNewsBean.isVisiable}"
            android:onClick="@{(view)->xItemClick.onItemClick(view,xNewsBean,3)}"
            android:text="@string/new_ui_upgrade"
            android:textColor="@color/main_text_color"
            app:layout_constraintRight_toRightOf="@+id/bannedUser"
            app:layout_constraintTop_toTopOf="@+id/userName" />

        <TextView
            android:id="@+id/rechargeButton"
            style="@style/new_ui_agent_manager_recharge"
            android:layout_marginEnd="20dp"
            android:layout_marginRight="20dp"
            android:onClick="@{(view)->xItemClick.onItemClick(view,xNewsBean,1)}"
            android:text="@string/new_ui_recharge"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/bannedUser"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/bannedUser"
            style="@style/new_ui_agent_manager_recharge"
            android:layout_marginEnd="10dp"
            android:layout_marginRight="10dp"
            android:onClick="@{(view)->xItemClick.onItemClick(view,xNewsBean,2)}"
            android:text="@{xNewsBean.status==0?@string/new_ui_fengjin:@string/new_ui_forbidden}"
            android:textColor="@{xNewsBean.status==0?@color/new_ui_red_color:@color/gray_text_color}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>