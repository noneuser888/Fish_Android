<?xml version="1.0" encoding="utf-8"?>
<layout>

    <data >
        <variable
            name="xNewsBean"
            type="com.wantime.wbangapp.model.RechargeRecordBean.RecordsBean" />

        <variable
            name="xItemClick"
            type="com.wantime.wbangapp.ui.adapter.RecyclerItemClick" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        style="@style/ui_common_wmatch_hwrap">

        <TextView
            android:id="@+id/userName"
            android:text="@{@string/new_ui_recharge_user_id+xNewsBean.userId}"
            style="@style/new_ui_agent_manager_item_name"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/rechargeType"
            style="@style/new_ui_recharge_item_desc"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:layout_constraintLeft_toLeftOf="@+id/userName"
            app:layout_constraintTop_toBottomOf="@+id/userName" />

        <TextView
            android:id="@+id/rechargeOrder"
            style="@style/new_ui_recharge_item_desc"
            android:text="@{@string/new_ui_order_id+xNewsBean.id}"
            app:layout_constraintLeft_toLeftOf="@+id/userName"
            app:layout_constraintTop_toBottomOf="@+id/rechargeType" />

        <TextView
            android:id="@+id/rechargeTime"
            style="@style/new_ui_recharge_item_desc"
            android:text="@{xNewsBean.time}"
            app:layout_constraintLeft_toLeftOf="@+id/userName"
            app:layout_constraintTop_toBottomOf="@+id/rechargeOrder" />

        <TextView
            android:id="@+id/rechargeMoney"
            style="@style/new_ui_recharge_money"
            android:text="@{@string/new_ui_reduce+String.valueOf(xNewsBean.amount)}"
            app:layout_constraintRight_toRightOf="@+id/rechargeBalance"
            app:layout_constraintTop_toTopOf="@+id/userName" />

        <TextView
            android:id="@+id/rechargeBalance"
            style="@style/new_ui_agent_manager_item_desc"
            android:layout_marginRight="10dp"
            android:layout_marginEnd="10dp"
            android:text="@{@string/new_ui_after_balance+xNewsBean.afterBalance}"
            app:layout_constraintBottom_toBottomOf="@+id/rechargeTime"
            app:layout_constraintRight_toRightOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>