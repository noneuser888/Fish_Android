<?xml version="1.0" encoding="utf-8"?>
<layout>

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.wantime.wbangapp.ui.widget.RoundableLayout
            android:id="@+id/layout_example"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_margin="10dp"
            app:cornerLeftBottom="10dp"
            app:cornerLeftTop="10dp"
            app:cornerRightBottom="10dp"
            app:cornerRightTop="10dp">

            <androidx.viewpager.widget.ViewPager
                android:id="@+id/mViewPager"
                style="@style/ui_platform_pager" />
        </com.wantime.wbangapp.ui.widget.RoundableLayout>

        <include layout="@layout/ui_adapter_platform_recycler_header_title" />

    </LinearLayout>
</layout>