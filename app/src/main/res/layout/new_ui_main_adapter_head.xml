<?xml version="1.0" encoding="utf-8"?>
<layout>

    <data>

        <variable
            name="xItemClick"
            type="com.wantime.wbangapp.ui.adapter.RecyclerItemClick" />

        <variable
            name="xUserBean"
            type="com.wantime.wbangapp.model.UserBean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        style="@style/ui_common_wmatch_hwrap">

        <com.wantime.wbangapp.ui.widget.IDrawQuad
            android:id="@+id/headImgBg"
            style="@style/new_ui_main_adpater_head_img_bg"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/userHeadImg"
            style="@style/new_ui_main_adapter_head_img"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/headImgLine"
            android:layout_width="1px"
            android:layout_height="5dp"
            app:layout_constraintBottom_toBottomOf="@+id/userHeadImg"
            app:layout_constraintLeft_toRightOf="@+id/userHeadImg"
            app:layout_constraintTop_toTopOf="@+id/userHeadImg" />

        <TextView
            android:id="@+id/userName"
            style="@style/new_ui_main_adapter_head_text"
            android:layout_marginStart="5dp"
            android:layout_marginLeft="5dp"
            android:text="@{xUserBean.phone}"
            app:layout_constraintBottom_toTopOf="@+id/headImgLine"
            app:layout_constraintLeft_toRightOf="@+id/userHeadImg" />


        <TextView
            android:id="@+id/userNick"
            style="@style/new_ui_main_adapter_head_text"
            android:text='@{xUserBean.nickname+"\n"+xUserBean.getUserLevel()}'
            app:layout_constraintLeft_toLeftOf="@+id/userName"
            app:layout_constraintTop_toBottomOf="@+id/headImgLine" />


        <TextView
            android:id="@+id/userType"
            style="@style/new_ui_main_adapter_head_text"
            android:layout_marginStart="15dp"
            android:layout_marginLeft="15dp"
            app:layout_constraintBottom_toBottomOf="@+id/userNick"
            app:layout_constraintLeft_toRightOf="@+id/userNick" />


        <TextView
            android:id="@+id/headMenu"
            style="@style/new_ui_main_adapter_head_menu"
            android:onClick="@{(view)->xItemClick.onItemClick(view,0)}"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/userHeadImg" />


        <TextView
            android:id="@+id/userBalance"
            style="@style/new_ui_main_adapter_head_text_balance"
            android:text="@{String.valueOf(xUserBean.balance)}"
            app:layout_constraintTop_toTopOf="@+id/userNick"
            app:layout_constraintRight_toRightOf="@+id/headMenu" />


        <com.wantime.wbangapp.ui.widget.RoundableLayout
            android:id="@+id/userMoreProject"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_margin="10dp"
            app:cornerLeftBottom="10dp"
            app:cornerLeftTop="10dp"
            app:cornerRightBottom="10dp"
            app:cornerRightTop="10dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/userNick">

            <androidx.viewpager.widget.ViewPager
                android:id="@+id/mViewPager"
                style="@style/ui_platform_pager" />
        </com.wantime.wbangapp.ui.widget.RoundableLayout>


        <LinearLayout
            android:id="@+id/menuLayout"
            style="@style/new_ui_main_adpater_head_menu_text_parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/userMoreProject">

            <TextView
                android:id="@+id/new_ui_platform"
                style="@style/new_ui_main_adpater_head_menu_text"
                android:drawableTop="@mipmap/pingtailiebiao"
                android:onClick="@{(view)->xItemClick.onItemClick(view,2)}"
                android:text="@string/new_ui_platform" />

            <TextView
                android:id="@+id/new_ui_grant_record"
                style="@style/new_ui_main_adpater_head_menu_text"
                android:drawableTop="@mipmap/shouquanjilu"
                android:onClick="@{(view)->xItemClick.onItemClick(view,3)}"
                android:text="@string/new_ui_grant_record" />

            <TextView
                android:id="@+id/new_ui_agent_manager"
                style="@style/new_ui_main_adpater_head_menu_text"
                android:drawableTop="@mipmap/dailiguanli"
                android:onClick="@{(view)->xItemClick.onItemClick(view,4)}"
                android:text="@string/new_ui_agent_manager" />

            <TextView
                android:id="@+id/new_ui_user_manager"
                style="@style/new_ui_main_adpater_head_menu_text"
                android:drawableTop="@mipmap/yonghuguanli"
                android:onClick="@{view->xItemClick.onItemClick(view,5)}"
                android:text="@string/new_ui_user_manager" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            style="@style/ui_common_wmatch_hwrap"
            android:paddingBottom="5dp"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/menuLayout">

            <TextView
                android:id="@+id/copyButton"
                style="@style/new_ui_main_adpater_head_my_copy"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <TextView
                android:id="@+id/copyLinkText"
                style="@style/new_ui_main_adpater_head_my_link"
                android:text="@{@string/new_ui_my_ad_link+xUserBean.inviteUrl}"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@+id/copyButton"
                app:layout_constraintTop_toTopOf="@+id/copyButton" />

            <TextView
                android:id="@+id/copyLinkText1"
                style="@style/new_ui_main_adpater_head_my_link"
                android:text='@{@string/new_ui_invite_code + xUserBean.inviteCode}'
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@+id/copyButton"
                app:layout_constraintTop_toBottomOf="@+id/copyLinkText" />


            <TextView
                style="@style/new_ui_main_adpater_head_title"
                app:layout_constraintLeft_toLeftOf="parent"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toBottomOf="@+id/copyLinkText1" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>