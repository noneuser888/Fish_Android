<?xml version="1.0" encoding="utf-8"?>
<layout>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:background="@color/gray_text_color4"
        style="@style/ui_common_wmatch_hwrap">

        <com.wantime.wbangapp.ui.widget.IDrawQuad
            android:id="@+id/headImgBg"
            style="@style/new_ui_main_adpater_head_img_bg"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <include
            android:id="@+id/mNavigationBar"
            layout="@layout/ui_top_navigation" />

        <include
            android:id="@+id/personInfoLayout"
            layout="@layout/new_ui_head_user_info_show" />


        <TextView
            android:id="@+id/userMyAgent"
            style="@style/new_ui_agent_adapter_head_my_agent"
            android:layout_marginStart="20dp"
            android:layout_marginLeft="20dp"
            app:layout_constraintBottom_toBottomOf="@+id/searchView"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="@+id/searchView" />

        <com.wantime.wbangapp.ui.widget.SearchView
            android:id="@+id/searchView"
            style="@style/new_ui_agent_adapter_head_agent_edit"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/personInfoLayout" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>