<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="itemBean"
            type="com.wantime.wbangapp.model.LoginAuthorityBean.ListBean.RecordsBean" />

        <variable
            name="itemClick"
            type="com.wantime.wbangapp.ui.adapter.RecyclerItemClick" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        style="@style/ui_adapter_record_item"
        android:onClick="@{(view)->itemClick.onItemClick(view,itemBean)}">

        <ImageView
            android:id="@+id/recordItem"
            style="@style/ui_adapter_record_item_icon"
            app:imgPath="@{itemBean.imageUrl}"
            android:onClick="@{(view)->itemClick.onItemClick(view,itemBean)}"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/recordName"
            style="@style/ui_adapter_record_item_name"
            android:text="@{itemBean.platformName}"
            app:layout_constraintLeft_toRightOf="@+id/recordItem"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/recordType"
            style="@style/ui_adapter_record_item_desc"
            android:text="@{itemBean.typeName}"
            android:layout_marginTop="2dp"
            app:layout_constraintLeft_toLeftOf="@+id/recordName"
            app:layout_constraintTop_toBottomOf="@+id/recordName" />

        <TextView
            android:id="@+id/recordPrice"
            style="@style/ui_adapter_record_item_desc"
            android:layout_marginTop="5dp"
            android:text='@{@string/ui_kou_fei+String.valueOf(itemBean.price)}'
            android:textColor="@color/price_text_color"
            app:layout_constraintLeft_toLeftOf="@+id/recordName"
            app:layout_constraintTop_toBottomOf="@+id/recordType" />


        <TextView
            android:id="@+id/orderInfo"
            style="@style/ui_adapter_record_item_desc"
            android:layout_marginTop="5dp"
            android:text='@{@string/ui_mark+String.valueOf(itemBean.info)}'
            android:textColor="@color/new_main_color"
            app:layout_constraintLeft_toLeftOf="@+id/recordName"
            app:layout_constraintTop_toBottomOf="@+id/recordPrice" />

          <!--订单号-->
        <!--ID-->
        <TextView
            android:id="@+id/IdText"
            style="@style/ui_adapter_record_item_desc"
            android:layout_marginRight="70dp"
            android:text='@{(itemBean.taskName.length>0)?(@string/ui_id+itemBean.taskId):""}'
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/recordName" />

<!--        <TextView-->
<!--            android:id="@+id/orderNumber"-->
<!--            style="@style/ui_adapter_record_item_desc"-->
<!--            android:text='@{@string/new_ui_order_id+itemBean.id}'-->
<!--            android:textColor="@color/bg_login_color"-->
<!--            app:layout_constraintTop_toTopOf="@+id/recordName"-->
<!--            app:layout_constraintRight_toRightOf="parent" />-->

        <!--昵称 -->
        <TextView
            android:id="@+id/nickName"
            style="@style/ui_adapter_record_item_desc"
            android:layout_marginRight="70dp"
            android:text='@{(itemBean.nickName.length>0)?(@string/ui_nick+itemBean.wxUserNickname):""}'
            android:textColor="@color/bg_login_color"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@+id/recordType" />


        <TextView
            android:id="@+id/recordTime"
            style="@style/ui_adapter_record_item_desc"
            android:layout_marginTop="5dp"
            android:layout_marginRight="10dp"
            android:text="@{itemBean.createTime}"
            app:layout_constraintRight_toLeftOf="@+id/buttonContainer"
            app:layout_constraintTop_toBottomOf="@+id/nickName" />

        <!-- 按钮容器 -->
        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_marginRight="5dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/renewalButton"
                android:layout_width="55dp"
                android:layout_height="32dp"
                android:layout_marginEnd="5dp"
                android:layout_marginRight="5dp"
                android:enabled='@{(itemBean.type!=0)}'
                android:text="续费"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white_text_color"
                android:background="@color/price_text_color"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:gravity="center"
                android:onClick="@{(view)->itemClick.onItemClick(view,itemBean)}"/>

            <Button
                android:id="@+id/button"
                android:layout_width="55dp"
                android:layout_height="32dp"
                android:enabled='@{(itemBean.type!=0)}'
                android:text="复扫"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:gravity="center"
                android:onClick="@{(view)->itemClick.onItemClick(view,itemBean)}"/>

        </LinearLayout>
        <View
            android:layout_width="0dp"
            android:layout_height="1px"
            android:background="@color/gray_line_color"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="@+id/recordName"
            app:layout_constraintRight_toRightOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
